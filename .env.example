# =========================
# LLM Configuration
# =========================
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# =========================
# Database (Production - PostgreSQL)
# =========================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/legalai
SPRING_DATASOURCE_USERNAME=legalai
SPRING_DATASOURCE_PASSWORD=legalai_secret

# =========================
# ChromaDB
# =========================
CHROMA_HOST=localhost
CHROMA_PORT=8001